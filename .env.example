# m-trans configuration. Copy to .env and fill in the keys you use.
# All keys are optional — only configure the translators/polish you need.

# ── Translator API keys ────────────────────────────────────────────────────
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
DEEPL_AUTH_KEY=
BAIDU_APP_ID=
BAIDU_SECRET_KEY=
YOUDAO_APP_KEY=
YOUDAO_APP_SECRET=

# ── Polish / LLM ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Service ─────────────────────────────────────────────────────────────────
# Bind host/port for the embedded backend. Desktop launcher picks a free port
# automatically when M_TRANS_PORT is unset; set here only for headless/server use.
# HOST=0.0.0.0
# PORT=8000

# ── Paths ───────────────────────────────────────────────────────────────────
# Override writable data dir (storage/, models/, etc.). Defaults to the
# directory containing the executable (frozen) or the project root (dev).
# M_TRANS_DATA_DIR=

# ── GPU ──────────────────────────────────────────────────────────────────────
# Enable CUDA inference. Requires the CUDA build of the app + a supported GPU.
USE_GPU=false
